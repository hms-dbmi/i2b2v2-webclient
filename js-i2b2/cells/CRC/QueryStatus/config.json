{
  "displayComponents": {
    "SUMMARY": {
      "source": "Summary/Summary.js",
      "CSS": "Summary/Summary.css",
      "alwaysShow": true,
      "noFrameTemplate": true,
      "notInReport": true
    },
    "COUNT": {
      "source": "Count/Count.js",
      "CSS": "Count/Count.css",
      "class": "patient-count",
      "alwaysShow": true,
      "noFrameTemplate": true
    },
    "SHRINESITES": {
      "name": "Table Summary",
      "source": "ShrineSites/ShrineSites.js",
      "CSS": "ShrineSites/ShrineSites.css",
      "iconClass": "bi bi-table",
      "alwaysShow": true
    },
    "BARS": {
      "name": "Bar Chart",
      "source": "BarGraph/BarGraph.js",
      "CSS": "BarGraph/BarGraph.css",
      "iconClass": "bi bi-bar-chart-line",
      "default": true,
      "displayOrder": 1,
      "class": "bargraph"
    },
    "PIECHART": {
      "name": "Pie Chart",
      "source": "PieChart/PieChart.js",
      "CSS": "PieChart/PieChart.css",
      "iconClass": "bi bi-pie-chart",
      "displayOrder": 2
    },
    "TABLE": {
      "name": "Table Summary",
      "source": "Table/Table.js",
      "CSS": "Table/Table.css",
      "iconClass": "bi bi-table",
      "displayOrder": 100,
      "displayForUnregistered": true
    },
    "DOWNLOAD": {
      "name": "CSV Download",
      "source": "Download/Download.js",
      "iconClass": "bi bi-filetype-csv",
      "displayOrder": 500,
      "displayForUnregistered": true,
      "notInReport": true
    },
    "SHRINESITESDOWNLOAD": {
      "name": "CSV Download",
      "source": "ShrineSitesDownload/Download.js",
      "iconClass": "bi bi-filetype-csv",
      "notInReport": true
    },
    "ZIPCODEMAP": {
      "name": "Map View",
      "source": "ZipcodeMap/ZipcodeMap.js",
      "CSS": "ZipcodeMap/ZipcodeMap.css",
      "iconClass": "bi bi-globe2"
    },
    "PATIENTCOUNTMAP": {
      "name": "Map Viewer",
      "source": "PatientCountMap/PatientCountMap.js",
      "CSS": "PatientCountMap/PatientCountMap.css",
      "iconClass": "bi bi-globe2",
      "displayOrder": 200,
      "displayForUnregistered": true,
      "notInReport": true
    },
    "LINECHART": {
      "name": "Line Chart",
      "source": "LineChart/LineChart.js",
      "CSS": "LineChart/LineChart.css",
      "iconClass": "bi bi-graph-up",
      "displayOrder": 3,
      "class": "linechart",
      "displayForUnregistered": false
    },
    "NIHENROLLTABLE": {
      "name": "Enrollment Form",
      "source": "NihEnrollTable/Table.js",
      "CSS": "NihEnrollTable/Table.css",
      "iconClass": "bi bi-grid-3x3",
      "displayOrder": 1
    }
  },
  "displayOrder": [
    "INTERNAL_SUMMARY",
    "PATIENT_COUNT_XML",
    "PATIENT_COUNT_SHRINE_XML",
    "PATIENT_SITE_COUNT_SHRINE_XML"
  ],
  "haltPollingOnStatus": [
    "COMPLETED",
    "FINISHED",
    "ERROR",
    "TIMEOUT"
  ]
}